<#
.SYNOPSIS
    Applies a standard configuration baseline across all IIS sites on this
    server: Windows Authentication (Kerberos-only), dual log targets, a
    default document, the Management Service, ASP session timeout, and
    Failed Request Tracing rules.

.DESCRIPTION
    For EVERY site returned by Get-Website, this script:

    1. Authentication
       - Enables Windows Authentication
       - Sets providers to ONLY "Negotiate:Kerberos" (removes Negotiate/NTLM
         fallback - Kerberos-only, no NTLM negotiation)
       - Disables useKernelMode (required when using Negotiate:Kerberos-only -
         see Microsoft guidance: kernel-mode auth must be off for this provider)
       - Disables Anonymous, Basic, and Digest authentication
         (Basic/Digest sections may not exist since those role services were
         never installed - handled gracefully if so)

    2. Logging
       - logFile.logTargetW3C = "File,ETW" (Log Event Destination: Both Log
         File and ETW Event), set at siteDefaults and per-site

    3. Default Document
       - Ensures "portal.htm" exists in the default document list and moves
         it to the TOP of the list (first document IIS will look for),
         applied at the server default and per-site

    4. Management Service (WMSVC)
       - Enables remote management (registry)
       - Redirects its logging to E:\Logs\WMSVC
       - Sets the service to Automatic startup and starts it

    5b. HTTP.sys parameters
       - HKLM\SYSTEM\CurrentControlSet\Services\HTTP\Parameters
         MaxFieldLength  = 0xfffe (DWORD)
         MaxRequestBytes = 0xfffe (DWORD)
       - NOTE: HTTP.sys is a kernel-mode driver; these only take effect after
         a full server restart, not just an IIS or service restart.

    5. ASP Session Properties
       - Classic ASP session timeout set to 15 minutes (system.webServer/asp/session)

    6. Failed Request Tracing Rules
       - Adds an "All content (*)" rule (path="*") per site, covering ALL
         four trace providers at Verbose: WWW Server, ASP, ISAPI Extension,
         and ASPNET, each with their full area sets, and a status code range
         of 100-999 (i.e. captures every status code - "all content" in the
         fullest sense).

.PARAMETER DefaultDocumentName
    Document to place at the top of the default document list. Default: portal.htm

.PARAMETER WmsvcLogDirectory
    Log directory for the Management Service. Default: E:\Logs\WMSVC

.PARAMETER AspSessionTimeoutMinutes
    Classic ASP session timeout, in minutes. Default: 15

.NOTES
    Run elevated. Backs up applicationHost.config before making changes.

    All four Failed Request Tracing providers are enabled (WWW Server, ASP,
    ISAPI Extension, ASPNET), each with their full documented area sets, per
    Microsoft's own traceProviderDefinitions schema. ASP and ISAPI Extension
    have no sub-areas of their own, so only provider + verbosity are set for
    those two.
#>

#Requires -RunAsAdministrator

[CmdletBinding(SupportsShouldProcess = $true)]
param(
    [string]$DefaultDocumentName        = 'portal.htm',
    [string]$WmsvcLogDirectory          = 'E:\Logs\WMSVC',
    [int]$AspSessionTimeoutMinutes       = 15
)

$ErrorActionPreference = 'Stop'
Import-Module WebAdministration

# Load explicitly rather than relying on WebAdministration having already
# pulled this into the AppDomain - usually true, but not guaranteed.
Add-Type -Path "$env:windir\System32\inetsrv\Microsoft.Web.Administration.dll" -ErrorAction SilentlyContinue

$BackupFolder     = 'C:\Config-Backups'
$Timestamp        = Get-Date -Format 'yyyyMMdd_HHmmss'
$BackupConfigPath = Join-Path $BackupFolder "applicationHost.config.bak_$Timestamp"
New-Item -ItemType Directory -Path $BackupFolder -Force | Out-Null

$transcriptPath = Join-Path $BackupFolder "Configure-IIS-Sites_$Timestamp.log"
Start-Transcript -Path $transcriptPath | Out-Null

Write-Host "==> Backing up applicationHost.config to $BackupConfigPath" -ForegroundColor Cyan
if ($PSCmdlet.ShouldProcess($BackupConfigPath, 'Copy applicationHost.config')) {
    Copy-Item 'C:\Windows\System32\inetsrv\config\applicationHost.config' $BackupConfigPath
}

# ---------------------------------------------------------------------------
# Capture pre-change state for registry/service items NOT covered by the
# applicationHost.config backup above, so Revert-IIS-Sites-Configuration.ps1
# can restore the server to exactly how it was, not just "some other value".
# For each item, $null means "did not exist before" (revert should remove it,
# not just set it to a value) rather than "existed and was null".
# ---------------------------------------------------------------------------
$wmsvcKeyPath = 'HKLM:\SOFTWARE\Microsoft\WebManagement\Server'
$httpKeyPath  = 'HKLM:\SYSTEM\CurrentControlSet\Services\HTTP\Parameters'

$preState = [PSCustomObject]@{
    Timestamp             = $Timestamp
    ConfigBackupPath      = $BackupConfigPath
    WmsvcKeyExisted       = Test-Path $wmsvcKeyPath
    WmsvcEnableRemoteMgmt = if (Test-Path $wmsvcKeyPath) { (Get-ItemProperty -Path $wmsvcKeyPath -Name EnableRemoteManagement -ErrorAction SilentlyContinue).EnableRemoteManagement } else { $null }
    WmsvcLoggingDirectory = if (Test-Path $wmsvcKeyPath) { (Get-ItemProperty -Path $wmsvcKeyPath -Name LoggingDirectory -ErrorAction SilentlyContinue).LoggingDirectory } else { $null }
    HttpKeyExisted        = Test-Path $httpKeyPath
    HttpMaxFieldLength    = if (Test-Path $httpKeyPath) { (Get-ItemProperty -Path $httpKeyPath -Name MaxFieldLength -ErrorAction SilentlyContinue).MaxFieldLength } else { $null }
    HttpMaxRequestBytes   = if (Test-Path $httpKeyPath) { (Get-ItemProperty -Path $httpKeyPath -Name MaxRequestBytes -ErrorAction SilentlyContinue).MaxRequestBytes } else { $null }
    WmsvcServiceExisted   = [bool](Get-Service -Name WMSVC -ErrorAction SilentlyContinue)
    WmsvcStartType        = (Get-Service -Name WMSVC -ErrorAction SilentlyContinue).StartType.ToString()
    WmsvcWasRunning       = (Get-Service -Name WMSVC -ErrorAction SilentlyContinue).Status -eq 'Running'
}
$StateFilePath = Join-Path $BackupFolder "Configure-IIS-Sites_state_$Timestamp.json"
$preState | ConvertTo-Json | Set-Content -Path $StateFilePath -Encoding UTF8
Write-Host "  Pre-change state saved to $StateFilePath (needed for rollback)" -ForegroundColor DarkGray

try {

$aspSessionTimeout = '{0:00}:{1:00}:00' -f [Math]::Floor($AspSessionTimeoutMinutes / 60), ($AspSessionTimeoutMinutes % 60)

# ---------------------------------------------------------------------------
# Helper: move a default document to the top of the list, using the
# Microsoft.Web.Administration API directly for reliable ordering (the
# WebAdministration cmdlets don't give reliable control over collection order).
# ---------------------------------------------------------------------------
function Set-DefaultDocumentTop {
    param(
        [Parameter(Mandatory)][string]$Location,   # '' for server default, or a site name
        [Parameter(Mandatory)][string]$DocumentName
    )
    $mgr = New-Object Microsoft.Web.Administration.ServerManager
    try {
        $config  = $mgr.GetApplicationHostConfiguration()
        $section = $config.GetSection('system.webServer/defaultDocument', $Location)
        $section['enabled'] = $true
        $files = $section.GetCollection('files')

        $existing = $files | Where-Object { $_.GetAttributeValue('value') -eq $DocumentName }
        if ($existing) { $files.Remove($existing) }

        $newElement = $files.CreateElement('add')
        $newElement.SetAttributeValue('value', $DocumentName)
        $files.AddAt(0, $newElement)

        $mgr.CommitChanges()
    }
    finally {
        # ServerManager holds file locks until disposed/GC'd
        $mgr.Dispose()
    }
}

# ---------------------------------------------------------------------------
# Per-site configuration
# ---------------------------------------------------------------------------
$sites = Get-Website
if (-not $sites) {
    Write-Warning "No IIS sites found via Get-Website."
}

$siteResults = @()

foreach ($site in $sites) {
    $sitePsPath = "IIS:\Sites\$($site.Name)"
    Write-Host "`n==> Configuring site: $($site.Name)" -ForegroundColor Cyan

    if (-not $PSCmdlet.ShouldProcess($site.Name, 'Apply configuration baseline')) { continue }

    try {
        # --- 1. Authentication ---------------------------------------------------
        Write-Host "  Setting Windows Authentication (Negotiate:Kerberos only, kernel-mode off)" -ForegroundColor DarkGray
        Set-WebConfigurationProperty -Filter 'system.webServer/security/authentication/windowsAuthentication' `
            -PSPath $sitePsPath -Name 'enabled' -Value $true
        Set-WebConfigurationProperty -Filter 'system.webServer/security/authentication/windowsAuthentication' `
            -PSPath $sitePsPath -Name 'useKernelMode' -Value $false

        Clear-WebConfiguration -Filter 'system.webServer/security/authentication/windowsAuthentication/providers' -PSPath $sitePsPath
        Add-WebConfiguration -Filter 'system.webServer/security/authentication/windowsAuthentication/providers' `
            -PSPath $sitePsPath -Value @{value = 'Negotiate:Kerberos' }

        Write-Host "  Disabling Anonymous / Basic / Digest authentication" -ForegroundColor DarkGray
        Set-WebConfigurationProperty -Filter 'system.webServer/security/authentication/anonymousAuthentication' `
            -PSPath $sitePsPath -Name 'enabled' -Value $false

        foreach ($authSection in 'basicAuthentication', 'digestAuthentication') {
            try {
                Set-WebConfigurationProperty -Filter "system.webServer/security/authentication/$authSection" `
                    -PSPath $sitePsPath -Name 'enabled' -Value $false -ErrorAction Stop
            }
            catch {
                Write-Host "    ($authSection section not present - role service not installed, nothing to disable)" -ForegroundColor DarkGray
            }
        }

        # --- 2. Logging ------------------------------------------------------------
        Write-Host "  Setting log event destination to File + ETW" -ForegroundColor DarkGray
        Set-ItemProperty -Path $sitePsPath -Name 'logFile.logTargetW3C' -Value 'File,ETW'

        # --- 3. Default document ----------------------------------------------------
        Write-Host "  Placing '$DefaultDocumentName' at the top of the default document list" -ForegroundColor DarkGray
        Set-DefaultDocumentTop -Location $site.Name -DocumentName $DefaultDocumentName

        # --- 5. ASP session timeout --------------------------------------------------
        Write-Host "  Setting ASP session timeout to $AspSessionTimeoutMinutes minutes" -ForegroundColor DarkGray
        Set-WebConfigurationProperty -Filter 'system.webServer/asp/session' -PSPath $sitePsPath `
            -Name 'timeout' -Value $aspSessionTimeout

        # --- 6. Failed Request Tracing rule: All content (*) --------------------------
        Write-Host "  Adding Failed Request Tracing rule: All content (*)" -ForegroundColor DarkGray
        Set-WebConfigurationProperty -Filter 'system.webServer/tracing/traceFailedRequestsLogging' `
            -PSPath $sitePsPath -Name 'enabled' -Value $true

        Clear-WebConfiguration -Filter 'system.webServer/tracing/traceFailedRequests' -PSPath $sitePsPath -ErrorAction SilentlyContinue
        Add-WebConfiguration -Filter 'system.webServer/tracing/traceFailedRequests' -PSPath $sitePsPath -Value @{path = '*' }
        Set-WebConfigurationProperty -Filter "system.webServer/tracing/traceFailedRequests/add[@path='*']/failureDefinitions" `
            -PSPath $sitePsPath -Name 'statusCodes' -Value '100-999'

        # Four FRT trace providers, each per Microsoft's traceProviderDefinitions
        # schema. ASP and ISAPI Extension have no sub-areas of their own, so
        # 'Areas' is $null for those two and simply omitted from the hashtable.
        $frtProviders = @(
            @{ Provider = 'WWW Server';      Areas = 'Authentication,Security,Filter,StaticFile,CGI,Compression,Cache,RequestNotifications,Module,FastCGI,WebSocket' }
            @{ Provider = 'ASP';              Areas = $null }
            @{ Provider = 'ISAPI Extension';  Areas = $null }
            @{ Provider = 'ASPNET';           Areas = 'Infrastructure,Module,Page,AppServices' }
        )
        foreach ($p in $frtProviders) {
            $value = @{ provider = $p.Provider; verbosity = 'Verbose' }
            if ($p.Areas) { $value['areas'] = $p.Areas }
            Add-WebConfiguration -Filter "system.webServer/tracing/traceFailedRequests/add[@path='*']/traceAreas" `
                -PSPath $sitePsPath -Value $value
        }

        $siteResults += [PSCustomObject]@{ Site = $site.Name; Status = 'OK'; Error = $null }
    }
    catch {
        Write-Warning "Configuration FAILED for site '$($site.Name)': $($_.Exception.Message)"
        Write-Warning "Continuing with remaining sites."
        $siteResults += [PSCustomObject]@{ Site = $site.Name; Status = 'FAILED'; Error = $_.Exception.Message }
    }
}

# ---------------------------------------------------------------------------
# Server-wide defaults (so anything created later inherits the same baseline)
# ---------------------------------------------------------------------------
Write-Host "`n==> Applying matching server-wide defaults (for future sites)" -ForegroundColor Cyan
if ($PSCmdlet.ShouldProcess('MACHINE/WEBROOT/APPHOST', 'Set server-wide defaults')) {
    Set-WebConfigurationProperty -Filter 'system.applicationHost/sites/siteDefaults/logFile' `
        -PSPath 'IIS:\' -Name 'logTargetW3C' -Value 'File,ETW'
    Set-DefaultDocumentTop -Location '' -DocumentName $DefaultDocumentName
    Set-WebConfigurationProperty -Filter 'system.webServer/asp/session' -PSPath 'MACHINE/WEBROOT/APPHOST' `
        -Name 'timeout' -Value $aspSessionTimeout -ErrorAction SilentlyContinue
}

# ---------------------------------------------------------------------------
# 4. Management Service (WMSVC)
# ---------------------------------------------------------------------------
Write-Host "`n==> Configuring Management Service (WMSVC)" -ForegroundColor Cyan
if ($PSCmdlet.ShouldProcess('WMSVC', 'Enable, redirect logging, start')) {
    New-Item -ItemType Directory -Path $WmsvcLogDirectory -Force | Out-Null

    # WMSVC does not always run as SYSTEM - grant whichever account it's
    # actually configured for explicit access to the new log folder, since
    # inherited permissions on E:\Logs may not cover that account and a
    # mismatch here causes WMSVC to silently fail to write its own logs.
    $wmsvcAccount = (Get-CimInstance Win32_Service -Filter "Name='WMSVC'" -ErrorAction SilentlyContinue).StartName
    if ($wmsvcAccount) {
        Write-Host "  WMSVC runs as '$wmsvcAccount' - granting it Modify on $WmsvcLogDirectory" -ForegroundColor DarkGray
        icacls $WmsvcLogDirectory /grant "${wmsvcAccount}:(OI)(CI)M" /T /C | Out-Null
    }

    $wmsvcKey = 'HKLM:\SOFTWARE\Microsoft\WebManagement\Server'
    if (-not (Test-Path $wmsvcKey)) {
        New-Item -Path $wmsvcKey -Force | Out-Null
    }
    Set-ItemProperty -Path $wmsvcKey -Name 'EnableRemoteManagement' -Value 1 -Type DWord
    Set-ItemProperty -Path $wmsvcKey -Name 'LoggingDirectory' -Value $WmsvcLogDirectory -Type String

    $wmsvcService = Get-Service -Name WMSVC -ErrorAction SilentlyContinue
    if (-not $wmsvcService) {
        Write-Warning "WMSVC service not found - is the 'Management Service' (Web-Mgmt-Service) role service installed?"
    }
    else {
        Set-Service -Name WMSVC -StartupType Automatic
        Start-Service -Name WMSVC
        Write-Host "  WMSVC set to Automatic and started. Logging to $WmsvcLogDirectory" -ForegroundColor Green
    }
}

# ---------------------------------------------------------------------------
# HTTP.sys parameters: MaxFieldLength / MaxRequestBytes
# ---------------------------------------------------------------------------
Write-Host "`n==> Setting HTTP.sys parameters (MaxFieldLength / MaxRequestBytes)" -ForegroundColor Cyan
$httpParamsKey = 'HKLM:\SYSTEM\CurrentControlSet\Services\HTTP\Parameters'
if ($PSCmdlet.ShouldProcess($httpParamsKey, 'Set MaxFieldLength / MaxRequestBytes')) {
    if (-not (Test-Path $httpParamsKey)) {
        New-Item -Path $httpParamsKey -Force | Out-Null
    }
    Set-ItemProperty -Path $httpParamsKey -Name 'MaxFieldLength' -Value 0xfffe -Type DWord
    Set-ItemProperty -Path $httpParamsKey -Name 'MaxRequestBytes' -Value 0xfffe -Type DWord
    Write-Host "  MaxFieldLength and MaxRequestBytes set to 0xfffe (65534)." -ForegroundColor Green
    Write-Warning "HTTP.sys is a kernel-mode driver - these values only take effect after a full server RESTART, not just an IIS/service restart. Reboot when convenient to apply them."
}

# ---------------------------------------------------------------------------
# Verification
# ---------------------------------------------------------------------------
Write-Host "`n==> Verification" -ForegroundColor Cyan
foreach ($site in Get-Website) {
    $sitePsPath = "IIS:\Sites\$($site.Name)"
    Write-Host "`n$($site.Name)" -ForegroundColor Yellow
    [PSCustomObject]@{
        WindowsAuthEnabled = (Get-WebConfigurationProperty -Filter 'system.webServer/security/authentication/windowsAuthentication' -PSPath $sitePsPath -Name enabled).Value
        UseKernelMode      = (Get-WebConfigurationProperty -Filter 'system.webServer/security/authentication/windowsAuthentication' -PSPath $sitePsPath -Name useKernelMode).Value
        Providers          = (Get-WebConfiguration -Filter 'system.webServer/security/authentication/windowsAuthentication/providers/add' -PSPath $sitePsPath | ForEach-Object { $_.value }) -join ', '
        AnonymousEnabled   = (Get-WebConfigurationProperty -Filter 'system.webServer/security/authentication/anonymousAuthentication' -PSPath $sitePsPath -Name enabled).Value
        LogTarget          = (Get-ItemProperty -Path $sitePsPath -Name logFile.logTargetW3C).Value
        DefaultDocsTop3    = ((Get-WebConfiguration -Filter 'system.webServer/defaultDocument/files/add' -PSPath $sitePsPath | Select-Object -First 3 -ExpandProperty value) -join ', ')
        AspSessionTimeout  = (Get-WebConfigurationProperty -Filter 'system.webServer/asp/session' -PSPath $sitePsPath -Name timeout).Value
        FrtRulePath        = (Get-WebConfiguration -Filter "system.webServer/tracing/traceFailedRequests/add" -PSPath $sitePsPath -ErrorAction SilentlyContinue | Select-Object -ExpandProperty path)
        FrtProviders       = ((Get-WebConfiguration -Filter "system.webServer/tracing/traceFailedRequests/add[@path='*']/traceAreas/add" -PSPath $sitePsPath -ErrorAction SilentlyContinue | ForEach-Object { $_.provider }) -join ', ')
    } | Format-List
}

Write-Host "`nWMSVC status:" -ForegroundColor Yellow
Get-Service -Name WMSVC -ErrorAction SilentlyContinue | Select-Object Name, Status, StartType

Write-Host "`nHTTP.sys parameters:" -ForegroundColor Yellow
Get-ItemProperty -Path $httpParamsKey -ErrorAction SilentlyContinue |
    Select-Object MaxFieldLength, MaxRequestBytes | Format-List
Write-Host "(A server restart is required for these to take effect if this is the first time they've been set.)" -ForegroundColor DarkGray

Write-Host "`nPer-site result summary:" -ForegroundColor Yellow
$siteResults | Format-Table -AutoSize

Write-Host @"

NOTE on Kerberos (useKernelMode = false): with kernel-mode auth disabled,
IIS decrypts Kerberos tickets in user mode using either the machine account
or the application pool identity (controlled by useAppPoolCredentials, left
at its default of false here - i.e. still the machine account). This works
out of the box for the common case (default ApplicationPoolIdentity, SPN
registered to the machine account). If any app pool here runs under a
custom domain service account with its own SPN, you'll also need to set
useAppPoolCredentials = true for that site, or Kerberos auth will fail.
"@ -ForegroundColor DarkGray

Write-Host "`nDone." -ForegroundColor Green
}
finally {
    Write-Host "`nTranscript saved to $transcriptPath" -ForegroundColor DarkGray
    Stop-Transcript | Out-Null
}
