& "$env:windir\System32\inetsrv\appcmd.exe" set config -section:system.web/authorization /+"deny.[users='?']" /commit:apphost

& "$env:windir\System32\inetsrv\appcmd.exe" list config -section:system.web/authorization
Get-WebConfiguration -Filter "system.web/authorization/deny" -PSPath 'MACHINE/WEBROOT/APPHOST'

Select-String -Path "C:\Windows\System32\inetsrv\config\applicationHost.config" -Pattern '<deny users'
Get-ChildItem C:\inetpub\wwwroot\web.config -ErrorAction SilentlyContinue | Get-Content | Select-String 'deny users'
