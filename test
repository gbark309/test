<#
.SYNOPSIS
    Sets correct, locked-down NTFS permissions on the relocated inetpub
    (D:\inetpub) and logs (E:\Logs) folders for IIS.

.DESCRIPTION
    Applies the standard Microsoft-recommended IIS permission model. For each
    path, ownership is set to BUILTIN\Administrators BEFORE granting - this
    means the grant step can never be blocked by a stuck ACL, an unexpected
    owner, or a stray Deny entry left over from a previous state, since the
    owner of an object can always rewrite its DACL regardless of what's
    currently on it.

    D:\inetpub (content root, e.g. wwwroot)
        SYSTEM               - Full Control   (OI)(CI)
        Administrators       - Full Control   (OI)(CI)
        IIS_IUSRS            - Read & Execute (OI)(CI)
        (all inherited permissions from the volume are stripped first)

    E:\Logs (W3C site logs go directly here - written by the WWW service as SYSTEM)
        SYSTEM               - Full Control   (OI)(CI)
        Administrators       - Full Control   (OI)(CI)
        IIS_IUSRS            - Read & Execute (OI)(CI)

    E:\Logs\FailedReqLogFiles (trace logs - written by the worker process,
    i.e. the application pool identity, which is a member of IIS_IUSRS)
        SYSTEM               - Full Control   (OI)(CI)
        Administrators       - Full Control   (OI)(CI)
        IIS_IUSRS            - Modify         (OI)(CI)   <-- needs write access

    Inheritance is disabled (protected) at D:\inetpub and E:\Logs so nothing
    unexpected is inherited from the volume root, and permissions are then
    applied recursively (/T) so existing content picks up the same ACEs.

    Before making any changes, current ACLs for both trees are saved to
    .txt files via icacls /save so they can be restored if needed.

.PARAMETER InetpubRoot
    Path to the relocated inetpub content root. Default: D:\inetpub

.PARAMETER LogsRoot
    Path to the relocated logs root. Default: E:\Logs

.PARAMETER BackupFolder
    Where to save the pre-change ACL backups. Default: C:\ACL-Backups

.PARAMETER LogRetentionDays
    Log/trace files older than this many days are deleted by the scheduled
    cleanup task. Default: 180 (~6 months).

.PARAMETER SkipScheduledTask
    If set, skips creating/updating the daily log-cleanup scheduled task.

.PARAMETER Environment
    Required. 'dev' grants DOMAIN\DevGroup Full Control on
    wwwroot\Contents; 'prod' grants DOMAIN\DevGroup Read & Execute only.

.NOTES
    Run elevated.
#>

#Requires -RunAsAdministrator

[CmdletBinding(SupportsShouldProcess = $true)]
param(
    [string]$InetpubRoot  = 'D:\inetpub',
    [string]$LogsRoot     = 'E:\Logs',
    [string]$BackupFolder = 'C:\ACL-Backups',
    [int]$LogRetentionDays = 180,
    [switch]$SkipScheduledTask,

    [Parameter(Mandatory)]
    [ValidateSet('dev', 'prod')]
    [string]$Environment
)

$ErrorActionPreference = 'Stop'

$LogFiles  = $LogsRoot   # W3C logs now live directly under LogsRoot, not a LogFiles subfolder
$TraceLogs = Join-Path $LogsRoot 'FailedReqLogFiles'
$Timestamp = Get-Date -Format 'yyyyMMdd_HHmmss'

foreach ($p in @($InetpubRoot, $LogsRoot, $TraceLogs)) {
    if (-not (Test-Path $p)) {
        throw "Path not found: $p. Run the relocation script first, or check the parameter values."
    }
}
# Note: wwwroot\Contents is created further down if it doesn't already exist -
# it is intentionally not required to pre-exist.

New-Item -ItemType Directory -Path $BackupFolder -Force | Out-Null

$transcriptPath = Join-Path $BackupFolder "Set-IIS-Permissions_$Timestamp.log"
Start-Transcript -Path $transcriptPath | Out-Null
Write-Host "Transcript logging to $transcriptPath" -ForegroundColor DarkGray

function Invoke-Icacls {
    param(
        [Parameter(Mandatory)][string[]]$IcaclsArgs,
        [Parameter(Mandatory)][string]$Description
    )
    Write-Host "  $Description" -ForegroundColor DarkGray
    Write-Host "    icacls $($IcaclsArgs -join ' ')" -ForegroundColor DarkGray
    if ($PSCmdlet.ShouldProcess($Description, 'icacls')) {
        $proc = Start-Process icacls -ArgumentList $IcaclsArgs -NoNewWindow -Wait -PassThru `
            -RedirectStandardOutput "$env:TEMP\icacls_out.txt" -RedirectStandardError "$env:TEMP\icacls_err.txt"
        if ($proc.ExitCode -ne 0) {
            Get-Content "$env:TEMP\icacls_err.txt" | Write-Warning
            throw "icacls failed (exit $($proc.ExitCode)) on: $Description"
        }
    }
}

function Set-IISPermissions {
    param(
        [Parameter(Mandatory)][string]$Path,
        [Parameter(Mandatory)][hashtable[]]$Grants,   # @{ Trustee = 'X'; Rights = 'F|M|RX' }
        [bool]$Recurse = $true
    )

    Write-Host "`n==> Securing $Path$(if (-not $Recurse) { ' (this folder only, not recursive)' })" -ForegroundColor Cyan

    # 1. Backup current ACL
    $backupFile = Join-Path $BackupFolder "$($Path -replace '[:\\]', '_')_$Timestamp.txt"
    Write-Host "  Backing up current ACL to $backupFile" -ForegroundColor DarkGray
    if ($PSCmdlet.ShouldProcess($backupFile, 'icacls /save')) {
        $saveArgs = @("`"$Path`"", '/save', "`"$backupFile`"", '/C')
        if ($Recurse) { $saveArgs += '/T' }
        Start-Process icacls -ArgumentList $saveArgs -NoNewWindow -Wait | Out-Null
    }

    # 2. Take ownership as Administrators BEFORE granting. This matters
    #    because /grant:r can still be blocked by an unexpected owner or a
    #    stray Deny ACE on the object; the owner can always rewrite the DACL
    #    regardless of its current contents, so doing this first makes the
    #    grant step below unconditionally reliable rather than dependent on
    #    whatever state the ACL happens to be in.
    $takeownArgs = @("`"$Path`"", '/setowner', '"BUILTIN\Administrators"')
    if ($Recurse) { $takeownArgs += '/T' }
    $takeownArgs += '/C'
    Invoke-Icacls -Description "Set owner to BUILTIN\Administrators on $Path$(if ($Recurse) { ' (recursive)' })" `
        -IcaclsArgs $takeownArgs

    # 3. Grant the new trustees, while the existing (inherited or
    #    legacy) ACEs are still in place. This is deliberately ordered before
    #    steps 4/5 below: /grant:r only ADDS an explicit ACE, it never removes
    #    access, so if this step fails partway (e.g. one trustee name doesn't
    #    resolve, or icacls hits a transient error), the folder still has
    #    whatever access it had before this script ran - never zero access.
    #    -Recurse:$false is used for D:\inetpub itself so this does NOT walk
    #    into temp\appPools (WAS manages its own per-app-pool isolated ACLs
    #    there - see note at the call site below).
    foreach ($g in $Grants) {
        $grantArgs = @("`"$Path`"", '/grant:r', "`"$($g.Trustee):(OI)(CI)$($g.Rights)`"", '/C')
        if ($Recurse) { $grantArgs += '/T' }
        Invoke-Icacls -Description "Grant $($g.Trustee) : $($g.Rights) on $Path$(if ($Recurse) { ' (recursive)' })" `
            -IcaclsArgs $grantArgs
    }

    # 4. Only after the new grants are confirmed in place: best-effort strip
    #    common overly-broad default groups.
    foreach ($trustee in 'Users', 'Authenticated Users', 'Everyone') {
        try {
            Invoke-Icacls -Description "Remove '$trustee' from $Path (if present)" `
                -IcaclsArgs @("`"$Path`"", '/remove:g', "`"$trustee`"")
        } catch {
            Write-Host "    ($trustee not present or already removed - continuing)" -ForegroundColor DarkGray
        }
    }

    # 5. Break inheritance last. This only strips INHERITED ACEs - the
    #    explicit grants from step 3 are untouched, so this is safe even if
    #    steps 3/4 above encountered partial issues.
    Invoke-Icacls -Description "Disable inheritance on $Path" `
        -IcaclsArgs @("`"$Path`"", '/inheritance:r')
}

# ---------------------------------------------------------------------------
# inetpub content root
# ---------------------------------------------------------------------------
try {
# IMPORTANT: applied WITHOUT recursion here. D:\inetpub\temp\appPools contains
# WAS-managed, per-app-pool isolated ACLs (each pool's temp config folder is
# deliberately protected/non-inheriting so pools can't read each other's
# config). A blanket recursive grant across the whole tree would stamp
# IIS_IUSRS/SYSTEM/Administrators onto those folders too, weakening that
# isolation - this is also what caused WAS to fail to start during this
# migration previously. Setting the root non-recursively still establishes
# (OI)(CI) inheritance for anything newly created under it going forward;
# existing content folders that actually need consistent permissions are
# handled explicitly, recursively, below.
Set-IISPermissions -Path $InetpubRoot -Recurse:$false -Grants @(
    @{ Trustee = 'SYSTEM';               Rights = 'F'  }
    @{ Trustee = 'BUILTIN\Administrators'; Rights = 'F'  }
    @{ Trustee = 'BUILTIN\IIS_IUSRS';    Rights = 'RX' }
)

# Recursively normalize permissions on existing content folders only -
# deliberately excludes temp\appPools (see note above) and the compression
# cache under temp, both of which IIS/WAS manage themselves.
foreach ($contentFolder in 'wwwroot', 'custerr', 'history') {
    $fullPath = Join-Path $InetpubRoot $contentFolder
    if (Test-Path $fullPath) {
        $grants = @(
            @{ Trustee = 'SYSTEM';               Rights = 'F'  }
            @{ Trustee = 'BUILTIN\Administrators'; Rights = 'F'  }
            @{ Trustee = 'BUILTIN\IIS_IUSRS';    Rights = 'RX' }
        )
        # NETWORK / NETWORK SERVICE are needed on wwwroot specifically - e.g.
        # for app pools running under the legacy NetworkService identity, or
        # other components that authenticate via those built-in accounts
        # rather than through IIS_IUSRS.
        if ($contentFolder -eq 'wwwroot') {
            $grants += @{ Trustee = 'NT AUTHORITY\NETWORK';         Rights = 'RX' }
            $grants += @{ Trustee = 'NT AUTHORITY\NETWORK SERVICE'; Rights = 'RX' }
        }
        Set-IISPermissions -Path $fullPath -Recurse:$true -Grants $grants
    }
}

# ---------------------------------------------------------------------------
# Contents folder under wwwroot - DevGroup's rights here depend on -Environment:
#   dev  -> Full Control (developers can deploy/modify content directly)
#   prod -> Read & Execute only (no direct write access in production)
# (inherits SYSTEM/Administrators/IIS_IUSRS from wwwroot above; this just
# adds an additional explicit grant for DevGroup on top of that)
# ---------------------------------------------------------------------------
$ContentsFolder = Join-Path $InetpubRoot 'wwwroot\Contents'
$devGroupRights = if ($Environment -eq 'dev') { 'F' } else { 'RX' }
$devGroupRightsLabel = if ($Environment -eq 'dev') { 'Full Control' } else { 'Read & Execute' }

Write-Host "`n==> Ensuring $ContentsFolder exists" -ForegroundColor Cyan
if (-not (Test-Path $ContentsFolder)) {
    if ($PSCmdlet.ShouldProcess($ContentsFolder, 'Create directory')) {
        New-Item -ItemType Directory -Path $ContentsFolder -Force | Out-Null
    }
}
else {
    Write-Host "  Already exists." -ForegroundColor DarkGray
}

Write-Host "`n==> Granting DOMAIN\DevGroup $devGroupRightsLabel on $ContentsFolder ($Environment)" -ForegroundColor Cyan
Invoke-Icacls -Description "Set owner to BUILTIN\Administrators on $ContentsFolder (recursive)" `
    -IcaclsArgs @("`"$ContentsFolder`"", '/setowner', '"BUILTIN\Administrators"', '/T', '/C')
Invoke-Icacls -Description "Grant DOMAIN\DevGroup $devGroupRightsLabel on $ContentsFolder (recursive)" `
    -IcaclsArgs @("`"$ContentsFolder`"", '/grant:r', "`"DOMAIN\DevGroup:(OI)(CI)$devGroupRights`"", '/T', '/C')


# ---------------------------------------------------------------------------
# Logs root (covers FailedReqLogFiles too; that folder gets an additional
# explicit Modify grant for IIS_IUSRS below)
# ---------------------------------------------------------------------------
Set-IISPermissions -Path $LogsRoot -Grants @(
    @{ Trustee = 'SYSTEM';               Rights = 'F'  }
    @{ Trustee = 'BUILTIN\Administrators'; Rights = 'F'  }
    @{ Trustee = 'BUILTIN\IIS_IUSRS';    Rights = 'RX' }
    @{ Trustee = 'DOMAIN\DevGroup';      Rights = 'RX' }
)

# FailedReqLogFiles is written by the worker process (app pool identity,
# a member of IIS_IUSRS) - it needs Modify, not just Read & Execute.
Write-Host "`n==> Granting IIS_IUSRS Modify on $TraceLogs (trace logs are written by worker processes)" -ForegroundColor Cyan
Invoke-Icacls -Description "Set owner to BUILTIN\Administrators on $TraceLogs (recursive)" `
    -IcaclsArgs @("`"$TraceLogs`"", '/setowner', '"BUILTIN\Administrators"', '/T', '/C')
Invoke-Icacls -Description "Grant BUILTIN\IIS_IUSRS Modify on $TraceLogs (recursive)" `
    -IcaclsArgs @("`"$TraceLogs`"", '/grant:r', '"BUILTIN\IIS_IUSRS:(OI)(CI)M"', '/T', '/C')

# ---------------------------------------------------------------------------
# Verification
# ---------------------------------------------------------------------------
Write-Host "`n==> Resulting permissions" -ForegroundColor Cyan
foreach ($p in @($InetpubRoot, $ContentsFolder, $LogsRoot, $TraceLogs)) {
    Write-Host "`n$p" -ForegroundColor Yellow
    icacls $p
}

Write-Host "`nDone. ACL backups saved under $BackupFolder (restore with: icacls <path> /restore <backupfile>)." -ForegroundColor Green

# ---------------------------------------------------------------------------
# Scheduled task: delete log/trace files older than $LogRetentionDays
# ---------------------------------------------------------------------------
if ($SkipScheduledTask) {
    Write-Host "`n-SkipScheduledTask specified - not creating the log-cleanup task." -ForegroundColor Yellow
}
else {
    Write-Host "`n==> Setting up daily log cleanup (retention: $LogRetentionDays days)" -ForegroundColor Cyan

    $scriptsFolder = 'C:\Scripts'
    New-Item -ItemType Directory -Path $scriptsFolder -Force | Out-Null
    $cleanupScriptPath = Join-Path $scriptsFolder 'Remove-OldIISLogs.ps1'

    # Single-quoted here-string: NO variable interpolation or escape processing
    # happens here, so the script content below is written to disk exactly as
    # written - avoiding a whole class of nested-quoting bugs. LogsRoot and
    # RetentionDays are supplied as real parameters, passed explicitly by the
    # scheduled task action below (not baked into the file via string
    # substitution), so this file never needs to be regenerated to change them.
    $cleanupScriptContent = @'
<#
.SYNOPSIS
    Deletes IIS log and trace files older than the given retention period.
    Generated by Set-IIS-Permissions.ps1. Safe to run manually; the scheduled
    task passes -LogsRoot and -RetentionDays explicitly each run.
#>
param(
    [Parameter(Mandatory)][string]$LogsRoot,
    [Parameter(Mandatory)][int]$RetentionDays,
    [string]$BackupFolder = 'C:\ACL-Backups'
)

$ErrorActionPreference = 'Stop'
New-Item -ItemType Directory -Path $BackupFolder -Force | Out-Null
$cutoff  = (Get-Date).AddDays(-$RetentionDays)
$logPath = Join-Path $BackupFolder ("LogCleanup_{0}.log" -f (Get-Date -Format 'yyyyMMdd_HHmmss'))

$deleted = New-Object System.Collections.Generic.List[string]
$errors  = New-Object System.Collections.Generic.List[string]

Get-ChildItem -Path $LogsRoot -Recurse -File -ErrorAction SilentlyContinue |
    Where-Object { $_.LastWriteTime -lt $cutoff } |
    ForEach-Object {
        try {
            Remove-Item -Path $_.FullName -Force -ErrorAction Stop
            $deleted.Add($_.FullName)
        }
        catch {
            $errors.Add("$($_.FullName): $($_.Exception.Message)")
        }
    }

# Clean up any now-empty subfolders left behind (e.g. old per-site W3SVC<id> folders)
Get-ChildItem -Path $LogsRoot -Recurse -Directory -ErrorAction SilentlyContinue |
    Sort-Object { $_.FullName.Length } -Descending |
    Where-Object { -not (Get-ChildItem -Path $_.FullName -Force -ErrorAction SilentlyContinue) } |
    Remove-Item -Force -ErrorAction SilentlyContinue

$summary = "{0} - Deleted {1} file(s) older than {2} days from {3}" -f (Get-Date -Format 'u'), $deleted.Count, $RetentionDays, $LogsRoot
$summary | Out-File -FilePath $logPath -Append

if ($deleted.Count -gt 0) {
    "Deleted files:" | Out-File -FilePath $logPath -Append
    $deleted | Out-File -FilePath $logPath -Append
}
if ($errors.Count -gt 0) {
    "Errors:" | Out-File -FilePath $logPath -Append
    $errors | Out-File -FilePath $logPath -Append
}
'@

    Set-Content -Path $cleanupScriptPath -Value $cleanupScriptContent -Encoding UTF8
    Write-Host "  Cleanup script written to $cleanupScriptPath" -ForegroundColor Green

    $taskName = 'IIS Log Cleanup'
    $existingTask = Get-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
    if ($existingTask) {
        Write-Host "  Existing scheduled task '$taskName' found - replacing it." -ForegroundColor DarkGray
        Unregister-ScheduledTask -TaskName $taskName -Confirm:$false
    }

    # LogsRoot/RetentionDays/BackupFolder passed explicitly here - the task
    # is fully self-describing and doesn't depend on defaults baked into the file.
    $taskArgs = "-NoProfile -ExecutionPolicy Bypass -File `"$cleanupScriptPath`" -LogsRoot `"$LogsRoot`" -RetentionDays $LogRetentionDays -BackupFolder `"$BackupFolder`""

    $action    = New-ScheduledTaskAction -Execute 'powershell.exe' -Argument $taskArgs
    $trigger   = New-ScheduledTaskTrigger -Daily -At '3:00AM'
    $principal = New-ScheduledTaskPrincipal -UserId 'SYSTEM' -LogonType ServiceAccount -RunLevel Highest
    $settings  = New-ScheduledTaskSettingsSet -StartWhenAvailable -ExecutionTimeLimit (New-TimeSpan -Hours 1)

    Register-ScheduledTask -TaskName $taskName -Action $action -Trigger $trigger `
        -Principal $principal -Settings $settings `
        -Description "Deletes IIS log/trace files under $LogsRoot older than $LogRetentionDays days. Runs daily at 3:00 AM as SYSTEM." | Out-Null

    Write-Host "  Scheduled task '$taskName' registered - runs daily at 3:00 AM as SYSTEM." -ForegroundColor Green
    Write-Host "  Run it on demand with: Start-ScheduledTask -TaskName '$taskName'" -ForegroundColor DarkGray
}
}
finally {
    Write-Host "`nTranscript saved to $transcriptPath" -ForegroundColor DarkGray
    Stop-Transcript | Out-Null
}
