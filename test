<#
.SYNOPSIS
    Reverts changes made by Configure-IIS-Sites.ps1: restores
    applicationHost.config from its pre-change backup, and restores the
    WMSVC/HTTP.sys registry values and WMSVC service state to what they were
    before that script ran.

.DESCRIPTION
    Configure-IIS-Sites.ps1 saves two files per run under -BackupFolder:
        applicationHost.config.bak_<timestamp>   - full config backup
        Configure-IIS-Sites_state_<timestamp>.json - registry/service snapshot

    This script uses that pair to fully roll back:
        1. Stops IIS (so applicationHost.config can be safely replaced)
        2. Restores applicationHost.config from the backup - this alone
           reverts every site/server-level IIS config change (authentication,
           logging, default document, ASP session timeout, FRT rules,
           siteDefaults)
        3. Restores WMSVC and HTTP.sys registry values to their prior state -
           if a value didn't exist before, it's removed rather than merely
           reset to something else. If an entire key didn't exist before
           (e.g. WebManagement\Server), the whole key is removed.
        4. Restores the WMSVC service's StartType and running/stopped state
        5. Restarts IIS

.PARAMETER Timestamp
    Which run to revert (format: yyyyMMdd_HHmmss). If omitted, the most
    recent state file under -BackupFolder is used automatically.

.PARAMETER BackupFolder
    Where Configure-IIS-Sites.ps1 saved its backups. Default: C:\Config-Backups

.PARAMETER ListBackups
    Lists available backup timestamps and exits without changing anything.

.NOTES
    Run elevated. Supports -WhatIf.
    NOTE: HTTP.sys is a kernel-mode driver - reverting MaxFieldLength /
    MaxRequestBytes in the registry still requires a full server restart
    before the reverted values actually take effect.
#>

#Requires -RunAsAdministrator

[CmdletBinding(SupportsShouldProcess = $true, ConfirmImpact = 'High')]
param(
    [string]$Timestamp,
    [string]$BackupFolder = 'C:\Config-Backups',
    [switch]$ListBackups
)

$ErrorActionPreference = 'Stop'

if (-not (Test-Path $BackupFolder)) {
    throw "Backup folder $BackupFolder not found - nothing to revert from."
}

$stateFiles = Get-ChildItem -Path $BackupFolder -Filter 'Configure-IIS-Sites_state_*.json' -ErrorAction SilentlyContinue |
    Sort-Object LastWriteTime -Descending

if ($ListBackups) {
    Write-Host "==> Available Configure-IIS-Sites.ps1 runs in $BackupFolder" -ForegroundColor Cyan
    if (-not $stateFiles) {
        Write-Host "  (none found)" -ForegroundColor DarkGray
    }
    $stateFiles | ForEach-Object {
        $ts = $_.BaseName -replace '.*_(\d{8}_\d{6})$', '$1'
        Write-Host "  $ts   ($($_.LastWriteTime))"
    }
    return
}

if (-not $stateFiles) {
    throw "No 'Configure-IIS-Sites_state_*.json' files found under $BackupFolder. Nothing to revert."
}

if ($Timestamp) {
    $stateFile = $stateFiles | Where-Object { $_.Name -like "*_$Timestamp.json" } | Select-Object -First 1
    if (-not $stateFile) {
        throw "No state file found matching timestamp '$Timestamp'. Run with -ListBackups to see what's available."
    }
}
else {
    $stateFile = $stateFiles | Select-Object -First 1
    Write-Host "No -Timestamp specified - using most recent run: $($stateFile.Name)" -ForegroundColor Yellow
}

$state = Get-Content -Path $stateFile.FullName -Raw | ConvertFrom-Json

if (-not (Test-Path $state.ConfigBackupPath)) {
    throw "Config backup referenced by this state file is missing: $($state.ConfigBackupPath)"
}

Write-Host "==> Reverting Configure-IIS-Sites.ps1 run from $($state.Timestamp)" -ForegroundColor Cyan
Write-Host "  Config backup: $($state.ConfigBackupPath)"

# ---------------------------------------------------------------------------
# 1. Stop IIS
# ---------------------------------------------------------------------------
Write-Host "`n==> Stopping IIS" -ForegroundColor Cyan
if ($PSCmdlet.ShouldProcess('W3SVC, WAS', 'Stop services')) {
    Stop-Service W3SVC -Force -ErrorAction SilentlyContinue
    Stop-Service WAS -Force -ErrorAction SilentlyContinue
}

try {
    # -----------------------------------------------------------------------
    # 2. Restore applicationHost.config
    # -----------------------------------------------------------------------
    Write-Host "`n==> Restoring applicationHost.config" -ForegroundColor Cyan
    if ($PSCmdlet.ShouldProcess('applicationHost.config', "Restore from $($state.ConfigBackupPath)")) {
        Copy-Item -Path $state.ConfigBackupPath -Destination 'C:\Windows\System32\inetsrv\config\applicationHost.config' -Force
        Write-Host "  Restored." -ForegroundColor Green
    }

    # -----------------------------------------------------------------------
    # 3. Restore registry values
    # -----------------------------------------------------------------------
    Write-Host "`n==> Restoring registry values" -ForegroundColor Cyan
    $wmsvcKeyPath = 'HKLM:\SOFTWARE\Microsoft\WebManagement\Server'
    $httpKeyPath  = 'HKLM:\SYSTEM\CurrentControlSet\Services\HTTP\Parameters'

    if (-not $state.WmsvcKeyExisted) {
        Write-Host "  $wmsvcKeyPath did not exist before - removing it entirely" -ForegroundColor DarkGray
        if ($PSCmdlet.ShouldProcess($wmsvcKeyPath, 'Remove key')) {
            Remove-Item -Path $wmsvcKeyPath -Recurse -Force -ErrorAction SilentlyContinue
        }
    }
    else {
        foreach ($pair in @(
                @{ Name = 'EnableRemoteManagement'; Value = $state.WmsvcEnableRemoteMgmt; Type = 'DWord' }
                @{ Name = 'LoggingDirectory';        Value = $state.WmsvcLoggingDirectory; Type = 'String' }
            )) {
            if ($null -eq $pair.Value) {
                Write-Host "  $($pair.Name) did not exist before - removing it" -ForegroundColor DarkGray
                if ($PSCmdlet.ShouldProcess("$wmsvcKeyPath\$($pair.Name)", 'Remove value')) {
                    Remove-ItemProperty -Path $wmsvcKeyPath -Name $pair.Name -ErrorAction SilentlyContinue
                }
            }
            else {
                Write-Host "  Restoring $($pair.Name) = $($pair.Value)" -ForegroundColor DarkGray
                if ($PSCmdlet.ShouldProcess("$wmsvcKeyPath\$($pair.Name)", 'Restore value')) {
                    Set-ItemProperty -Path $wmsvcKeyPath -Name $pair.Name -Value $pair.Value -Type $pair.Type
                }
            }
        }
    }

    if (-not $state.HttpKeyExisted) {
        Write-Host "  $httpKeyPath did not exist before - removing it entirely" -ForegroundColor DarkGray
        if ($PSCmdlet.ShouldProcess($httpKeyPath, 'Remove key')) {
            Remove-Item -Path $httpKeyPath -Recurse -Force -ErrorAction SilentlyContinue
        }
    }
    else {
        foreach ($pair in @(
                @{ Name = 'MaxFieldLength';  Value = $state.HttpMaxFieldLength }
                @{ Name = 'MaxRequestBytes'; Value = $state.HttpMaxRequestBytes }
            )) {
            if ($null -eq $pair.Value) {
                Write-Host "  $($pair.Name) did not exist before - removing it" -ForegroundColor DarkGray
                if ($PSCmdlet.ShouldProcess("$httpKeyPath\$($pair.Name)", 'Remove value')) {
                    Remove-ItemProperty -Path $httpKeyPath -Name $pair.Name -ErrorAction SilentlyContinue
                }
            }
            else {
                Write-Host "  Restoring $($pair.Name) = $($pair.Value)" -ForegroundColor DarkGray
                if ($PSCmdlet.ShouldProcess("$httpKeyPath\$($pair.Name)", 'Restore value')) {
                    Set-ItemProperty -Path $httpKeyPath -Name $pair.Name -Value ([int]$pair.Value) -Type DWord
                }
            }
        }
    }
    Write-Warning "HTTP.sys is a kernel-mode driver - a full server restart is required before the reverted MaxFieldLength/MaxRequestBytes values actually take effect."

    # -----------------------------------------------------------------------
    # 4. Restore WMSVC service state
    # -----------------------------------------------------------------------
    Write-Host "`n==> Restoring WMSVC service state" -ForegroundColor Cyan
    if ($state.WmsvcServiceExisted -and (Get-Service -Name WMSVC -ErrorAction SilentlyContinue)) {
        if ($PSCmdlet.ShouldProcess('WMSVC', "Set StartType=$($state.WmsvcStartType), Running=$($state.WmsvcWasRunning)")) {
            Set-Service -Name WMSVC -StartupType $state.WmsvcStartType
            if ($state.WmsvcWasRunning) {
                Start-Service -Name WMSVC -ErrorAction SilentlyContinue
            }
            else {
                Stop-Service -Name WMSVC -Force -ErrorAction SilentlyContinue
            }
            Write-Host "  WMSVC StartType restored to $($state.WmsvcStartType); running=$($state.WmsvcWasRunning)" -ForegroundColor Green
        }
    }
    else {
        Write-Host "  WMSVC service was not present before, or is not present now - nothing to restore." -ForegroundColor DarkGray
    }
}
finally {
    # -----------------------------------------------------------------------
    # 5. Restart IIS
    # -----------------------------------------------------------------------
    Write-Host "`n==> Restarting IIS" -ForegroundColor Cyan
    Start-Service WAS -ErrorAction SilentlyContinue
    Start-Service W3SVC -ErrorAction SilentlyContinue
}

# ---------------------------------------------------------------------------
# Verification
# ---------------------------------------------------------------------------
Write-Host "`n==> Verification" -ForegroundColor Cyan
foreach ($svcName in 'WAS', 'W3SVC', 'WMSVC') {
    $svc = Get-Service -Name $svcName -ErrorAction SilentlyContinue
    if ($svc) {
        Write-Host "  $svcName : $($svc.Status), StartType=$($svc.StartType)"
    }
}

Write-Host "`nDone. Sites/server config restored from $($state.ConfigBackupPath)." -ForegroundColor Green
