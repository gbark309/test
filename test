# .NET Authorization - where does the deny rule actually live?
Get-WebConfiguration -Filter "system.web/authorization/deny[@users='?']" -PSPath 'MACHINE/WEBROOT/APPHOST' -ErrorAction SilentlyContinue
Get-WebConfiguration -Filter "system.web/authorization/deny[@users='?']" -PSPath 'MACHINE/WEBROOT/APPHOST/Default Web Site' -ErrorAction SilentlyContinue

# WMSVC actual state
Get-Service WMSVC | Select-Object Name, Status, StartType

# Default document - server vs site
Get-WebConfiguration -Filter 'system.webServer/defaultDocument/files/add' -PSPath 'MACHINE/WEBROOT/APPHOST' | Select-Object value
Get-WebConfiguration -Filter 'system.webServer/defaultDocument/files/add' -PSPath 'MACHINE/WEBROOT/APPHOST/Default Web Site' | Select-Object value
