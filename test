<#
.SYNOPSIS
    Reverts changes made by Set-IIS-Permissions.ps1: restores NTFS permissions
    from the ACL backups it saved, removes the DevGroup grant on
    wwwroot\Contents (not covered by any backup, since that folder was newly
    created by that script), and removes the "IIS Log Cleanup" scheduled task
    and its script.

.DESCRIPTION
    For each of the following paths, finds the matching icacls backup file
    under -BackupFolder and restores it:
        D:\inetpub
        D:\inetpub\wwwroot
        D:\inetpub\custerr   (if a backup exists)
        D:\inetpub\history   (if a backup exists)
        E:\Logs

    By default the MOST RECENT backup found for each path is used
    independently. If Set-IIS-Permissions.ps1 was only run once, this is
    exactly the pre-change state. If it was run multiple times, pass
    -Timestamp to pick one specific run's snapshot consistently across all
    paths instead (recommended when in doubt - see -ListBackups).

    wwwroot\Contents did not exist before Set-IIS-Permissions.ps1 created it,
    so there is no ACL backup for it. This script instead just removes the
    DOMAIN\DevGroup grant that was added there (leaving the folder itself and
    its inherited SYSTEM/Administrators/IIS_IUSRS permissions untouched).

.PARAMETER InetpubRoot
    Must match the value used when Set-IIS-Permissions.ps1 ran. Default: D:\inetpub

.PARAMETER LogsRoot
    Must match the value used when Set-IIS-Permissions.ps1 ran. Default: E:\Logs

.PARAMETER BackupFolder
    Where the ACL backups and cleanup script live. Default: C:\ACL-Backups

.PARAMETER Timestamp
    Optional. Restore a specific backup run (format: yyyyMMdd_HHmmss) instead
    of independently picking the latest backup for each path.

.PARAMETER ListBackups
    Lists available backup timestamps per path and exits without changing
    anything.

.PARAMETER KeepScheduledTask
    If set, leaves the "IIS Log Cleanup" scheduled task and its script in place.

.PARAMETER KeepDevGroupGrant
    If set, leaves the DOMAIN\DevGroup grant on wwwroot\Contents in place.

.NOTES
    Run elevated. Supports -WhatIf.
#>

#Requires -RunAsAdministrator

[CmdletBinding(SupportsShouldProcess = $true, ConfirmImpact = 'High')]
param(
    [string]$InetpubRoot  = 'D:\inetpub',
    [string]$LogsRoot     = 'E:\Logs',
    [string]$BackupFolder = 'C:\ACL-Backups',
    [string]$Timestamp,
    [switch]$ListBackups,
    [switch]$KeepScheduledTask,
    [switch]$KeepDevGroupGrant
)

$ErrorActionPreference = 'Stop'

if (-not (Test-Path $BackupFolder)) {
    throw "Backup folder $BackupFolder not found - nothing to revert from."
}

# Paths that Set-IIS-Permissions.ps1 may have backed up, in restore order
# (children before/after parent doesn't matter for icacls /restore, but we
# list root first for readability).
$pathsToRestore = @(
    $InetpubRoot,
    (Join-Path $InetpubRoot 'wwwroot'),
    (Join-Path $InetpubRoot 'custerr'),
    (Join-Path $InetpubRoot 'history'),
    $LogsRoot
)

function Get-BackupPrefix {
    param([string]$Path)
    return ($Path -replace '[:\\]', '_')
}

function Get-BackupFilesFor {
    param([string]$Path)
    $prefix = Get-BackupPrefix -Path $Path
    Get-ChildItem -Path $BackupFolder -Filter "$prefix`_*.txt" -ErrorAction SilentlyContinue |
        Sort-Object LastWriteTime -Descending
}

if ($ListBackups) {
    Write-Host "==> Available backups in $BackupFolder" -ForegroundColor Cyan
    foreach ($path in $pathsToRestore) {
        $files = Get-BackupFilesFor -Path $path
        Write-Host "`n$path" -ForegroundColor Yellow
        if ($files) {
            $files | ForEach-Object { Write-Host "  $($_.Name)  ($($_.LastWriteTime))" }
        }
        else {
            Write-Host "  (no backups found)" -ForegroundColor DarkGray
        }
    }
    return
}

Write-Host "==> Reverting NTFS permissions" -ForegroundColor Cyan

$usedTimestamps = @{}

foreach ($path in $pathsToRestore) {
    if (-not (Test-Path $path)) {
        Write-Host "  Skipping $path (does not exist)" -ForegroundColor DarkGray
        continue
    }

    $files = Get-BackupFilesFor -Path $path
    if (-not $files) {
        Write-Warning "No backup found for $path - skipping (permissions here were not changed by, or backed up by, Set-IIS-Permissions.ps1)."
        continue
    }

    if ($Timestamp) {
        $chosen = $files | Where-Object { $_.Name -like "*_$Timestamp.txt" } | Select-Object -First 1
        if (-not $chosen) {
            Write-Warning "No backup for $path matches timestamp $Timestamp - skipping this path."
            continue
        }
    }
    else {
        $chosen = $files | Select-Object -First 1
    }

    $fileTimestamp = $chosen.BaseName -replace '.*_(\d{8}_\d{6})$', '$1'
    $usedTimestamps[$path] = $fileTimestamp

    Write-Host "  Restoring $path from $($chosen.Name)" -ForegroundColor Yellow
    if ($PSCmdlet.ShouldProcess($path, "icacls /restore $($chosen.FullName)")) {
        $proc = Start-Process icacls -ArgumentList @("`"$path`"", '/restore', "`"$($chosen.FullName)`"", '/C') -NoNewWindow -Wait -PassThru
        if ($proc.ExitCode -ne 0) {
            Write-Warning "icacls /restore returned exit code $($proc.ExitCode) for $path - verify manually with: icacls `"$path`""
        }
        else {
            Write-Host "    Restored." -ForegroundColor Green
        }
    }
}

if (-not $Timestamp -and ($usedTimestamps.Values | Select-Object -Unique).Count -gt 1) {
    Write-Warning "Backups restored came from DIFFERENT runs (mixed timestamps below). If Set-IIS-Permissions.ps1 ran more than once, consider re-running this script with -Timestamp to use one consistent snapshot."
    $usedTimestamps.GetEnumerator() | ForEach-Object { Write-Host "  $($_.Key): $($_.Value)" -ForegroundColor DarkGray }
}

# ---------------------------------------------------------------------------
# wwwroot\Contents - no backup exists (folder was newly created), so just
# remove the DevGroup grant that was added rather than attempting a restore.
# ---------------------------------------------------------------------------
if (-not $KeepDevGroupGrant) {
    $contentsFolder = Join-Path $InetpubRoot 'wwwroot\Contents'
    if (Test-Path $contentsFolder) {
        Write-Host "`n==> Removing DOMAIN\DevGroup grant on $contentsFolder" -ForegroundColor Cyan
        if ($PSCmdlet.ShouldProcess($contentsFolder, 'Remove DOMAIN\DevGroup grant')) {
            $proc = Start-Process icacls -ArgumentList @("`"$contentsFolder`"", '/remove:g', '"DOMAIN\DevGroup"', '/T', '/C') -NoNewWindow -Wait -PassThru
            if ($proc.ExitCode -eq 0) {
                Write-Host "  Removed." -ForegroundColor Green
            }
            else {
                Write-Warning "Could not remove the grant automatically (exit $($proc.ExitCode)) - check manually with: icacls `"$contentsFolder`""
            }
        }
    }
}
else {
    Write-Host "`n-KeepDevGroupGrant specified - leaving DOMAIN\DevGroup on wwwroot\Contents." -ForegroundColor Yellow
}

# ---------------------------------------------------------------------------
# Scheduled task + generated cleanup script
# ---------------------------------------------------------------------------
if (-not $KeepScheduledTask) {
    $taskName = 'IIS Log Cleanup'
    $task = Get-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
    if ($task) {
        Write-Host "`n==> Removing scheduled task '$taskName'" -ForegroundColor Cyan
        if ($PSCmdlet.ShouldProcess($taskName, 'Unregister scheduled task')) {
            Unregister-ScheduledTask -TaskName $taskName -Confirm:$false
            Write-Host "  Removed." -ForegroundColor Green
        }
    }

    $cleanupScript = 'C:\Scripts\Remove-OldIISLogs.ps1'
    if (Test-Path $cleanupScript) {
        Write-Host "==> Removing generated cleanup script $cleanupScript" -ForegroundColor Cyan
        if ($PSCmdlet.ShouldProcess($cleanupScript, 'Remove file')) {
            Remove-Item -Path $cleanupScript -Force
            Write-Host "  Removed." -ForegroundColor Green
        }
    }
}
else {
    Write-Host "`n-KeepScheduledTask specified - leaving the scheduled task and cleanup script in place." -ForegroundColor Yellow
}

# ---------------------------------------------------------------------------
# Verification
# ---------------------------------------------------------------------------
Write-Host "`n==> Resulting permissions" -ForegroundColor Cyan
foreach ($path in $pathsToRestore) {
    if (Test-Path $path) {
        Write-Host "`n$path" -ForegroundColor Yellow
        icacls $path
    }
}

Write-Host "`nDone." -ForegroundColor Green
